{
  "name": "gaoshuo-steel-wire-rope",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:products": "tsx scripts/validate-products.ts",
    "check:links": "tsx scripts/check-links.ts",
    "check:seo": "tsx scripts/check-seo.ts",
    "check:content": "tsx scripts/check-content.ts",
    "check:brand-migration": "tsx scripts/check-brand-migration.ts",
    "check:contact-leaks": "tsx scripts/check-contact-leaks.ts",
    "check:brand": "npm run check:brand-migration",
    "check:contacts": "npm run check:contact-leaks",
    "check:duplicate-products": "tsx scripts/check-duplicate-products.ts",
    "audit:reports": "tsx scripts/generate-audit-reports.ts",
    "report:products": "tsx scripts/generate-product-report.ts",
    "test": "vitest run",
    "verify": "npm run lint && npm run typecheck && npm run validate:products && npm run check:content && npm run check:duplicate-products && npm run check:brand-migration && npm run check:contact-leaks && npm run check:links && npm run check:seo && npm run test && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "gray-matter": "^4.0.3",
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.31.0",
    "eslint-config-next": "^15.3.5",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
